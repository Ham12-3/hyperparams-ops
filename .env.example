# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=optuna
POSTGRES_USER=optuna
POSTGRES_PASSWORD=optuna

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Study configuration
STUDY_NAME=cifar10-hpo
N_TRIALS=20
MAX_EPOCHS=10
PRUNER_TYPE=hyperband

# Search space
LR_LOW=1e-5
LR_HIGH=1e-1
BATCH_SIZES=[32, 64, 128]
NUM_LAYERS_LOW=2
NUM_LAYERS_HIGH=5
DROPOUT_LOW=0.1
DROPOUT_HIGH=0.5
OPTIMIZERS=["adam", "sgd", "adamw", "rmsprop"]

# K8s (only for K8s deployment)
ENABLE_K8S=false
K8S_NAMESPACE=hyperparams-ops
WORKER_IMAGE=hyperparams-ops-worker:latest
MAX_PARALLEL_TRIALS=4

# Dashboard
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
